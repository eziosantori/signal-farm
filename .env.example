# Alpaca Markets API credentials
# Get them from: https://app.alpaca.markets → API Keys
# Paper trading keys work fine for historical data access
ALPACA_API_KEY=your_api_key_here
ALPACA_SECRET_KEY=your_secret_key_here

# Oanda v20 REST API credentials
# Get API token from: https://www.oanda.com/account/tpa/personal_token
# OANDA_ENV: "practice" (default) or "live"
OANDA_API_KEY=your_oanda_api_token_here
OANDA_ENV=practice
